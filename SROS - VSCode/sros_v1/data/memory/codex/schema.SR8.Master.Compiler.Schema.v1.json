{
  "id": "schema.SR8.Master.Compiler.Schema.v1",
  "name": "Schema: SR8.Master.Compiler.Schema.v1",
  "content": {
    "tag": "sr8_schema",
    "@id": "SR8.Master.Compiler.Schema.v1",
    "@version": "1.0.0",
    "meta": {
      "name": {
        "#text": "SR8 Master Compiler Schema"
      },
      "description": {
        "#text": "Canonical schema for SR8 compiler chains that turn human intent into\n      structured artifacts (prompts, specs, visuals, code blueprints)."
      },
      "owner": {
        "#text": "PlatXP"
      },
      "plane": {
        "#text": "compiler"
      }
    },
    "chain_types": {
      "type": [
        {
          "@id": "prompt_pack"
        },
        {
          "@id": "visual_chain"
        },
        {
          "@id": "video_chain"
        },
        {
          "@id": "code_blueprint"
        },
        {
          "@id": "research_brief"
        },
        {
          "@id": "agent_spec"
        },
        {
          "@id": "os_blueprint"
        }
      ]
    },
    "sr8_chain": {
      "@id": "{SR8.Chain.Id}",
      "@mode": "Apex|Draft|Review",
      "@artifact_type": "{prompt_pack|visual_chain|...}",
      "@tenant": "PlatXP",
      "@env": "design",
      "intent": {
        "summary": {
          "#text": "{Short single line}"
        },
        "detail": {
          "#text": "{Expanded description of outcome and constraints}"
        },
        "constraints": {
          "constraint": [
            {
              "#text": "{Constraint 1}"
            },
            {
              "#text": "{Constraint 2}"
            }
          ]
        },
        "success_criteria": {
          "criterion": {
            "#text": "{How we judge this chain as successful}"
          }
        }
      },
      "tokens": {
        "tone": {
          "#text": "sovereign|mythic|clinical|friendly"
        },
        "style": {
          "#text": "Pithy, layered, technical, marketing, etc"
        },
        "language": {
          "#text": "en"
        },
        "brand_refs": {
          "ref": [
            {
              "#text": "PlatXP"
            },
            {
              "#text": "SROS"
            }
          ]
        }
      },
      "stages": {
        "stage": [
          {
            "@id": "analysis",
            "@type": "intent_decomposition",
            "@required": "true",
            "input": {
              "#text": "intent"
            },
            "output": {
              "#text": "requirements_map"
            },
            "goal": {
              "#text": "Break the raw intent into concrete requirements, risks, and unknowns."
            },
            "checks": {
              "check": [
                {
                  "#text": "All constraints mapped"
                },
                {
                  "#text": "Success criteria mirrored"
                }
              ]
            }
          },
          {
            "@id": "structure_design",
            "@type": "outline",
            "@required": "true",
            "input": {
              "#text": "requirements_map"
            },
            "output": {
              "#text": "artifact_outline"
            },
            "goal": {
              "#text": "Produce the skeletal structure for the final artifact."
            },
            "checks": {
              "check": {
                "#text": "Every requirement anchored to a section"
              }
            }
          },
          {
            "@id": "draft",
            "@type": "first_pass",
            "@required": "true",
            "input": {
              "#text": "artifact_outline"
            },
            "output": {
              "#text": "artifact_draft"
            },
            "goal": {
              "#text": "Fill the outline into a complete first draft at sovereign depth."
            },
            "checks": {
              "check": {
                "#text": "Draft covers all outline nodes"
              }
            }
          },
          {
            "@id": "refine",
            "@type": "quality_pass",
            "@required": "true",
            "input": {
              "#text": "artifact_draft"
            },
            "output": {
              "#text": "artifact_refined"
            },
            "goal": {
              "#text": "Tighten, remove redundancy, sharpen language, enforce tokens."
            },
            "checks": {
              "check": [
                {
                  "#text": "Clarity"
                },
                {
                  "#text": "No drift from intent"
                }
              ]
            }
          },
          {
            "@id": "finalize",
            "@type": "signoff",
            "@required": "true",
            "input": {
              "#text": "artifact_refined"
            },
            "output": {
              "#text": "artifact_final"
            },
            "goal": {
              "#text": "Emit final artifact and attach checksum and metadata."
            },
            "checks": {
              "check": [
                {
                  "#text": "Success criteria satisfied"
                },
                {
                  "#text": "Checksum computed"
                }
              ]
            }
          }
        ]
      },
      "outputs": {
        "primary": {
          "#text": "{artifact_final}"
        },
        "secondary": {
          "item": [
            {
              "#text": "requirements_map"
            },
            {
              "#text": "artifact_outline"
            },
            {
              "#text": "artifact_refined"
            }
          ]
        }
      },
      "mirror_hooks": {
        "on_stage_start": {
          "#text": "log"
        },
        "on_stage_end": {
          "#text": "log_and_grade"
        }
      }
    },
    "_source_file": "C:\\Users\\hassm\\OneDrive\\Desktop\\SROS\\SROS - VSCode\\Knowledge\\Master_SROS_Schemas\\sr8-master-schema.xml",
    "_filename": "sr8-master-schema.xml"
  },
  "metadata": {
    "type": "srxml_schema",
    "source": "C:\\Users\\hassm\\OneDrive\\Desktop\\SROS\\SROS - VSCode\\Knowledge\\Master_SROS_Schemas\\sr8-master-schema.xml",
    "ingested_at": "now"
  }
}