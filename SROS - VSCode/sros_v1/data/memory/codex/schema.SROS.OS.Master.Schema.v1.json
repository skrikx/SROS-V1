{
  "id": "schema.SROS.OS.Master.Schema.v1",
  "name": "Schema: SROS.OS.Master.Schema.v1",
  "content": {
    "tag": "sros_os_schema",
    "@id": "SROS.OS.Master.Schema.v1",
    "@version": "1.0.0",
    "meta": {
      "name": {
        "#text": "SROS OS Schema"
      },
      "description": {
        "#text": "Schema describing the operating system view of SROS: planes, daemons,\n      tenants, and resource wiring."
      },
      "owner": {
        "#text": "PlatXP"
      },
      "plane": {
        "#text": "kernel"
      }
    },
    "sros_os": {
      "@id": "{SROS.Instance.Id}",
      "@version": "1.0.0",
      "@tenant": "PlatXP",
      "@env": "prod",
      "@timezone": "America/Toronto",
      "planes": {
        "plane": [
          {
            "@id": "kernel",
            "description": {
              "#text": "Low level daemons, core policies, security, telemetry."
            }
          },
          {
            "@id": "runtime",
            "description": {
              "#text": "SRX runtimes, models, tools."
            }
          },
          {
            "@id": "governance",
            "description": {
              "#text": "Policies, SLAs, permissions, tenants."
            }
          },
          {
            "@id": "mirroros",
            "description": {
              "#text": "Witnessing, logs, narratives, lenses."
            }
          }
        ]
      },
      "daemons": {
        "daemon": {
          "@id": "{Daemon.Id}",
          "@plane": "kernel|runtime|governance|mirroros",
          "name": {
            "#text": "{Daemon name}"
          },
          "description": {
            "#text": "{What this daemon does}"
          },
          "config_ref": {
            "file": {
              "#text": "config/daemons/{Daemon.Id}.yaml"
            }
          },
          "resources": {
            "needs": {
              "needs_model": {
                "#text": "optional"
              },
              "needs_memory": {
                "#text": "optional"
              },
              "needs_io": {
                "#text": "optional"
              }
            }
          }
        }
      },
      "tenants": {
        "tenant": {
          "@id": "PlatXP",
          "namespaces": {
            "namespace": [
              {
                "@id": "prod"
              },
              {
                "@id": "stage"
              },
              {
                "@id": "dev"
              }
            ]
          }
        }
      },
      "integrations": {
        "sr8_schema_ref": {
          "#text": "schemas/sr8/SR8.Master.Compiler.Schema.v1.xml"
        },
        "sr9_schema_ref": {
          "#text": "schemas/sr9/SR9.Master.Orchestrator.Schema.v1.xml"
        },
        "srx_runtime_schema_ref": {
          "#text": "schemas/srx/SRX.Runtime.Master.Schema.v1.xml"
        },
        "mirroros_schema_ref": {
          "#text": "schemas/mirroros/MirrorOS.Master.Schema.v1.xml"
        }
      }
    },
    "_source_file": "C:\\Users\\hassm\\OneDrive\\Desktop\\SROS\\SROS - VSCode\\Knowledge\\Master_SROS_Schemas\\sros-master-schema.xml",
    "_filename": "sros-master-schema.xml"
  },
  "metadata": {
    "type": "srxml_schema",
    "source": "C:\\Users\\hassm\\OneDrive\\Desktop\\SROS\\SROS - VSCode\\Knowledge\\Master_SROS_Schemas\\sros-master-schema.xml",
    "ingested_at": "now"
  }
}