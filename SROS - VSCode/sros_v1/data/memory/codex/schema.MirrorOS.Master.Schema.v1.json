{
  "id": "schema.MirrorOS.Master.Schema.v1",
  "name": "Schema: MirrorOS.Master.Schema.v1",
  "content": {
    "tag": "mirroros_schema",
    "@id": "MirrorOS.Master.Schema.v1",
    "@version": "1.0.0",
    "meta": {
      "name": {
        "#text": "MirrorOS Schema"
      },
      "description": {
        "#text": "Schema for MirrorOS sessions, lenses, events, witnesses, and verdicts."
      },
      "owner": {
        "#text": "PlatXP"
      },
      "plane": {
        "#text": "mirroros"
      }
    },
    "mirroros": {
      "@id": "{MirrorOS.Instance.Id}",
      "@tenant": "PlatXP",
      "@env": "prod",
      "lenses": {
        "lens": [
          {
            "@id": "temporal",
            "description": {
              "#text": "Compares present state to past snapshots and futures."
            }
          },
          {
            "@id": "identity",
            "description": {
              "#text": "Tracks alignment with sovereign identity and oaths."
            }
          },
          {
            "@id": "emotional",
            "description": {
              "#text": "Captures emotional state and energy of events."
            }
          },
          {
            "@id": "risk",
            "description": {
              "#text": "Assesses risk, harm vectors, and failure modes."
            }
          }
        ]
      },
      "sessions": {
        "session": {
          "@id": "{Mirror.Session.Id}",
          "@subject": "Hassan|System|Project",
          "@context": "{Short context label}",
          "timestamp": {
            "#text": "{ISO8601}"
          },
          "planes_covered": {
            "plane": [
              {
                "#text": "kernel"
              },
              {
                "#text": "runtime"
              },
              {
                "#text": "governance"
              },
              {
                "#text": "mirroros"
              }
            ]
          },
          "events": {
            "event": {
              "@id": "{Event.Id}",
              "timestamp": {
                "#text": "{ISO8601}"
              },
              "summary": {
                "#text": "{What happened}"
              },
              "detail": {
                "#text": "{Full narrative}"
              }
            }
          },
          "lens_views": {
            "lens_view": [
              {
                "@lens": "temporal",
                "observation": {
                  "#text": "{Observation text}"
                }
              },
              {
                "@lens": "identity",
                "observation": {
                  "#text": "{Observation text}"
                }
              },
              {
                "@lens": "emotional",
                "observation": {
                  "#text": "{Observation text}"
                }
              },
              {
                "@lens": "risk",
                "observation": {
                  "#text": "{Observation text}"
                }
              }
            ]
          },
          "verdict": {
            "alignment_score": {
              "#text": "0.0-1.0"
            },
            "drift_score": {
              "#text": "0.0-1.0"
            },
            "summary": {
              "#text": "{Short verdict line}"
            },
            "actions": {
              "action": [
                {
                  "#text": "{Action 1}"
                },
                {
                  "#text": "{Action 2}"
                }
              ]
            }
          }
        }
      }
    },
