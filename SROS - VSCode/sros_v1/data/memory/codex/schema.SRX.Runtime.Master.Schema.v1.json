{
  "id": "schema.SRX.Runtime.Master.Schema.v1",
  "name": "Schema: SRX.Runtime.Master.Schema.v1",
  "content": {
    "tag": "srx_runtime_schema",
    "@id": "SRX.Runtime.Master.Schema.v1",
    "@version": "1.0.0",
    "meta": {
      "name": {
        "#text": "SRX Runtime Schema"
      },
      "description": {
        "#text": "Schema defining how SRX agents, models, memory, and tools are registered\n      and executed inside SROS."
      },
      "owner": {
        "#text": "PlatXP"
      },
      "plane": {
        "#text": "runtime"
      }
    },
    "srx_runtime": {
      "@id": "{SRX.Runtime.Id}",
      "@tenant": "PlatXP",
      "@env": "prod",
      "models": {
        "model": {
          "@id": "{Model.Id}",
          "@provider": "openai|google|local",
          "@family": "gpt|gemma|qwen|custom",
          "@context_window": "256000",
          "@temperature": "0.0-1.0",
          "@top_p": "0.1-1.0",
          "@max_output_tokens": "8000",
          "label": {
            "#text": "{Friendly name}"
          },
          "usage": {
            "#text": "planner|executor|summarizer|critic|vision"
          }
        }
      },
      "tools": {
        "tool": {
          "@id": "{Tool.Id}",
          "@kind": "http|db|filesystem|custom",
          "name": {
            "#text": "{Tool name}"
          },
          "description": {
            "#text": "{What this tool is for}"
          },
          "endpoint": {
            "#text": "{URL or local ref}"
          }
        }
      },
      "memory_backends": {
        "backend": {
          "@id": "{Memory.Backend.Id}",
          "@type": "kv|vector|document|log",
          "@persistence": "ephemeral|durable",
          "location": {
            "#text": "{db url or file path}"
          }
        }
      },
      "agents": {
        "srx_agent": {
          "@id": "{SRX.Agent.Id}",
          "@role": "{Agent high level role}",
          "@mode": "Apex|Lite|Review",
          "@srx_ace": "true|false",
          "@one_pass_lock": "true|false",
          "@drift_lock": "true|false",
          "identity": {
            "name": {
              "#text": "{Agent name}"
            },
            "purpose": {
              "#text": "{What this agent exists to do}"
            }
          },
          "model_ref": {
            "@id": "{Model.Id}"
          },
          "memory": {
            "short_term": {
              "@backend": "{Memory.Backend.Id}"
            },
            "long_term": {
              "@backend": "{Memory.Backend.Id}"
            },
            "sessions": {
              "@backend": "{Memory.Backend.Id}"
            }
          },
          "tool_refs": {
            "tool_ref": {
              "@id": "{Tool.Id}"
            }
          },
          "policy": {
            "max_tokens_per_call": {
              "#text": "4000"
            },
            "max_calls_per_session": {
              "#text": "20"
            }
          },
          "system_prompt_ref": {
            "file": {
              "#text": "schemas/prompts/{SRX.Agent.Id}.srxml"
            }
          }
        }
      }
    },
    "_source_file": "C:\\Users\\hassm\\OneDrive\\Desktop\\SROS\\SROS - VSCode\\Knowledge\\Master_SROS_Schemas\\srx-master-schema.xml",
    "_filename": "srx-master-schema.xml"
  },
  "metadata": {
    "type": "srxml_schema",
    "source": "C:\\Users\\hassm\\OneDrive\\Desktop\\SROS\\SROS - VSCode\\Knowledge\\Master_SROS_Schemas\\srx-master-schema.xml",
    "ingested_at": "now"
  }
}