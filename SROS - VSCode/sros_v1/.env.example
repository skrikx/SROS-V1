# SROS v1 Environment Configuration
# 
# Copy this file to .env and populate with actual credentials
# NEVER commit .env to git — add to .gitignore
#
# Security: Store credentials in environment variables or secure vaults
# Do NOT paste credentials in chat or shared documents

# Google Gemini API
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI (if used)
AZURE_OPENAI_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# Local LLM Configuration (if running locally)
LOCAL_LLM_API_URL=http://localhost:8000
LOCAL_LLM_MODEL=llama-2-7b

# SROS Configuration
SROS_LOG_LEVEL=INFO
SROS_TRACE_PATH=./data/traces
SROS_TENANT_ID=default

# Database & Storage
DATABASE_URL=sqlite://./data/sros.db
VECTOR_DB_PATH=./data/chroma

# Runtime Configuration
SROS_MAX_TOKENS=4096
SROS_TIMEOUT_SECONDS=300

# MirrorOS Configuration
MIRROROS_TRACE_ENABLED=true
MIRROROS_SNAPSHOT_INTERVAL=3600
