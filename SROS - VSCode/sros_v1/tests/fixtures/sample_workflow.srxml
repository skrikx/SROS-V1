<?xml version="1.0" encoding="UTF-8"?>
<sr8_workflow 
    id="test.workflow.1" 
    version="1.0.0" 
    tenant="default"
    role="orchestration"
    mode="EXECUTION"
    xmlns="https://srx.sros/schema/v1">
    
    <identity>
        <system_name>Test Workflow</system_name>
        <purpose>A test workflow for SROS v1 verification</purpose>
    </identity>
    
    <context>
        <item>Test context 1</item>
    </context>
    
    <inputs>
        <item>Input 1</item>
    </inputs>
    
    <objectives>
        <item>Execute test steps</item>
        <item>Verify orchestration</item>
    </objectives>
    
    <step id="step1" order="1">
        <input>Test step 1 input</input>
    </step>
    
    <step id="step2" order="2">
        <input>Test step 2 input</input>
    </step>
    
    <checks>
        <item>Verify completion</item>
    </checks>
    
    <output_contract>
        <item>Output 1</item>
    </output_contract>
</sr8_workflow>
