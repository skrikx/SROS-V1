<mirroros_schema
  id="MirrorOS.Master.Schema.v1"
  xmlns="https://sros.skrikx/schema/mirroros/v1"
  version="1.0.0">

  <meta>
    <name>MirrorOS Schema</name>
    <description>
      Schema for MirrorOS sessions, lenses, events, witnesses, and verdicts.
    </description>
    <owner>PlatXP</owner>
    <plane>mirroros</plane>
  </meta>

  <!-- MirrorOS root -->
  <mirroros
    id="{MirrorOS.Instance.Id}"
    tenant="PlatXP"
    env="prod">

    <!-- Lens catalog -->
    <lenses>
      <lens id="temporal">
        <description>Compares present state to past snapshots and futures.</description>
      </lens>
      <lens id="identity">
        <description>Tracks alignment with sovereign identity and oaths.</description>
      </lens>
      <lens id="emotional">
        <description>Captures emotional state and energy of events.</description>
      </lens>
      <lens id="risk">
        <description>Assesses risk, harm vectors, and failure modes.</description>
      </lens>
    </lenses>

    <!-- Individual mirror sessions -->
    <sessions>

      <session
        id="{Mirror.Session.Id}"
        subject="Hassan|System|Project"
        context="{Short context label}">
        <timestamp>{ISO8601}</timestamp>

        <planes_covered>
          <plane>kernel</plane>
          <plane>runtime</plane>
          <plane>governance</plane>
          <plane>mirroros</plane>
        </planes_covered>

        <events>
          <event id="{Event.Id}">
            <timestamp>{ISO8601}</timestamp>
            <summary>{What happened}</summary>
            <detail>{Full narrative}</detail>
          </event>
        </events>

        <lens_views>
          <lens_view lens="temporal">
            <observation>{Observation text}</observation>
          </lens_view>
          <lens_view lens="identity">
            <observation>{Observation text}</observation>
          </lens_view>
          <lens_view lens="emotional">
            <observation>{Observation text}</observation>
          </lens_view>
          <lens_view lens="risk">
            <observation>{Observation text}</observation>
          </lens_view>
        </lens_views>

        <verdict>
          <alignment_score>0.0-1.0</alignment_score>
          <drift_score>0.0-1.0</drift_score>
          <summary>{Short verdict line}</summary>
          <actions>
            <action>{Action 1}</action>
            <action>{Action 2}</action>
          </actions>
        </verdict>

      </session>

    </sessions>

  </mirroros>

</mirroros_schema>
