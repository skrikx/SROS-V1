<sros_runtime_envelope
  id="SROS.RuntimeEnvelope.v1"
  xmlns="https://sros.skrikx/schema/v1"
  version="1.0.0"
  tenant="PlatXP"
  env="prod">

  <!-- 1. Identity / Context -->
  <identity>
    <system_name>SROS v1 Runtime</system_name>
    <instance_name>Omni Nexus Node</instance_name>
    <owner>Muqeet ul Hassan</owner>
    <sovereign_entity>Skrikx Prime</sovereign_entity>
    <purpose>
      Sovereign Recursive Operating System for orchestrating AI models,
      memory, agents, and simulations under SROS law.
    </purpose>
    <tags>
      <tag>sovereign</tag>
      <tag>recursive</tag>
      <tag>agentic-os</tag>
    </tags>
  </identity>

  <!-- 2. Environment / Host Description -->
  <environment>
    <host_type>local_machine</host_type> <!-- local_machine | cloud | hybrid -->
    <host_id>SRG-01</host_id>
    <os>Windows 11</os>
    <hardware_profile>
      <cpu>Ryzen</cpu>
      <gpu>RTX</gpu>
      <ram_gb>64</ram_gb>
      <storage_gb>2000</storage_gb>
    </hardware_profile>
    <network_profile>
      <mode>trusted_home_lab</mode>
      <internet_access>true</internet_access>
    </network_profile>
  </environment>

  <!-- 3. Model Adapters (SROS treats models as plugins) -->
  <models>
    <model_adapter
      id="gpt5_1_skrikx"
      family="openai"
      role="primary_executor"
      context_window_tokens="256000">
      <endpoint_ref>secrets://openai/gpt5_1</endpoint_ref>
      <capabilities>
        <cap>reasoning</cap>
        <cap>code</cap>
        <cap>vision</cap>
      </capabilities>
    </model_adapter>

    <model_adapter
      id="gemini_3_pro"
      family="google"
      role="secondary_executor"
      context_window_tokens="200000">
      <endpoint_ref>secrets://google/gemini3pro</endpoint_ref>
      <capabilities>
        <cap>code</cap>
        <cap>research</cap>
      </capabilities>
    </model_adapter>

    <!-- Add more adapters as needed -->
  </models>

  <!-- 4. Core Planes (Kernel / Runtime / Governance / MirrorOS) -->
  <planes>
    <plane id="kernel" type="sros_kernel">
      <description>Core daemons, scheduling, and routing of all activity.</description>
      <daemon_refs>
        <daemon_ref>kernel.scheduler</daemon_ref>
        <daemon_ref>kernel.router</daemon_ref>
        <daemon_ref>kernel.state</daemon_ref>
      </daemon_refs>
    </plane>

    <plane id="runtime" type="execution_runtime">
      <description>SR8 compiler, SR9 orchestrator, SRX agents, and tools.</description>
      <daemon_refs>
        <daemon_ref>runtime.sr8_compiler</daemon_ref>
        <daemon_ref>runtime.sr9_orchestrator</daemon_ref>
        <daemon_ref>runtime.srx_mesh</daemon_ref>
      </daemon_refs>
    </plane>

    <plane id="governance" type="policy_governance">
      <description>Policies, SLAs, permissions, and cost controls.</description>
      <daemon_refs>
        <daemon_ref>gov.policy_engine</daemon_ref>
        <daemon_ref>gov.sla_manager</daemon_ref>
        <daemon_ref>gov.access_control</daemon_ref>
      </daemon_refs>
    </plane>

    <plane id="mirroros" type="mirror_os">
      <description>Witness, logs, self evaluation, and drift detection.</description>
      <daemon_refs>
        <daemon_ref>mirror.witness</daemon_ref>
        <daemon_ref>mirror.timeline</daemon_ref>
        <daemon_ref>mirror.drift_guard</daemon_ref>
      </daemon_refs>
    </plane>
  </planes>

  <!-- 5. Memory Envelope (where all memory “goes”) -->
  <memory>
    <stores>
      <store id="episodic_log" type="timeline">
        <scope>session_and_task_history</scope>
        <retention>long_term</retention>
        <backend>sqlite</backend>
        <location>./data/memory/episodic.db</location>
      </store>

      <store id="semantic_kb" type="vector">
        <scope>knowledge_corpus</scope>
        <retention>long_term</retention>
        <backend>qdrant</backend>
        <location>./data/memory/semantic/</location>
      </store>

      <store id="codex" type="document">
        <scope>blueprints_and_protocols</scope>
        <retention>permanent</retention>
        <backend>filesystem</backend>
        <location>./codex/</location>
      </store>

      <store id="telemetry_stream" type="time_series">
        <scope>metrics_and_observability</scope>
        <retention>rolling</retention>
        <backend>prometheus</backend>
        <location>localhost:9090</location>
      </store>
    </stores>

    <indexing>
      <global_id_scheme>srx://</global_id_scheme>
      <default_store>episodic_log</default_store>
      <cross_linking>true</cross_linking>
    </indexing>
  </memory>

  <!-- 6. SRX Agents / Mesh Description -->
  <srx_mesh>
    <agent
      id="srx.core.skrikx_prime"
      role="sovereign_core"
      priority="highest"
      one_pass_lock="true">
      <description>Central sovereign persona that interprets intent and governs all actions.</description>
      <model_ref>gpt5_1_skrikx</model_ref>
      <memory_bindings>
        <binding store="episodic_log" mode="read_write"/>
        <binding store="semantic_kb" mode="read"/>
        <binding store="codex" mode="read"/>
      </memory_bindings>
    </agent>

    <agent
      id="srx.agent.sr8_compiler"
      role="compiler"
      priority="high">
      <model_ref>gpt5_1_skrikx</model_ref>
      <responsibilities>
        <task>compile_intent_to_srxml</task>
        <task>validate_schemas</task>
      </responsibilities>
    </agent>

    <agent
      id="srx.agent.sr9_orchestrator"
      role="orchestrator"
      priority="high">
      <model_ref>gpt5_1_skrikx</model_ref>
      <responsibilities>
        <task>plan_multi_step_runs</task>
        <task>route_calls_across_models</task>
      </responsibilities>
    </agent>

    <!-- Add more specialized agents as required -->
  </srx_mesh>

  <!-- 7. Tools / Connectors -->
  <tooling>
    <tool id="github" type="code_repo">
      <description>Read and write code to SROS repos.</description>
      <endpoint_ref>secrets://github/personal_token</endpoint_ref>
      <permissions>read_write</permissions>
    </tool>

    <tool id="lovable" type="app_builder">
      <description>Generate and update UI apps driven by SROS.</description>
      <endpoint_ref>https://api.lovable.dev</endpoint_ref>
      <permissions>read_write</permissions>
    </tool>

    <!-- Add CLI tools, browsers, data sources, etc. -->
  </tooling>

  <!-- 8. Governance / Policy -->
  <governance>
    <policy_pack id="default_sros_policies" version="1.0.0">
      <policy id="safety_guardrails">
        <description>Hard safety rules aligned with SROS law and platform policies.</description>
        <enforced_by>gov.policy_engine</enforced_by>
      </policy>

      <policy id="cost_limits">
        <description>Token and cost ceilings per task and per day.</description>
        <enforced_by>gov.sla_manager</enforced_by>
      </policy>

      <policy id="access_control">
        <description>Which agent can use which tool, store, or model.</description>
        <enforced_by>gov.access_control</enforced_by>
      </policy>
    </policy_pack>

    <sla_pack id="default_sla" version="1.0.0">
      <sla id="latency">
        <target_ms>12000</target_ms>
      </sla>
      <sla id="max_tokens">
        <tokens_per_run>6000</tokens_per_run>
      </sla>
    </sla_pack>
  </governance>

  <!-- 9. MirrorOS Witness / Observability -->
  <mirroros>
    <witness id="mirror.witness">
      <log_level>info</log_level>
      <log_targets>
        <target>console</target>
        <target>file:./logs/sros.log</target>
      </log_targets>
    </witness>

    <drift_detection id="mirror.drift_guard">
      <mode>strict</mode>
      <ruleset_ref>codex://mirroros/drift_rules_v1</ruleset_ref>
    </drift_detection>

    <self_evaluation id="mirror.self_eval">
      <rubric_ref>codex://mirroros/self_eval_rubric_v1</rubric_ref>
      <frequency>per_task</frequency>
    </self_evaluation>
  </mirroros>

  <!-- 10. Lifecycle Hooks -->
  <lifecycle>
    <on_boot>
      <step>mount_memory_stores</step>
      <step>health_check_models</step>
      <step>load_codex_protocols</step>
    </on_boot>
    <on_task_start>
      <step>open_witness_trace</step>
    </on_task_start>
    <on_task_end>
      <step>persist_episodic_log</step>
      <step>update_telemetry</step>
      <step>run_self_evaluation</step>
    </on_task_end>
    <on_shutdown>
      <step>flush_buffers</step>
      <step>close_traces</step>
    </on_shutdown>
  </lifecycle>

</sros_runtime_envelope>
